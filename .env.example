# De-Brill Learn — Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API key (server-side only, no VITE_ prefix)
# Set this in your Vercel dashboard environment variables
# NEVER commit the actual key to git
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Base URL for the frontend to reach the API
# Use /api on Vercel or the local Vite app, or point it to another backend origin if needed
VITE_API_BASE_URL=/api
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
